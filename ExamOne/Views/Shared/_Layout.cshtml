@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestToken()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://use.fontawesome.com/releases/v5.15.4/css/all.css"
          integrity="sha384-DyZ88mC6Up2uqS4h/KRgHuoeGwBcD4Ng9SiP4dIRy0EXTlnuz47vAwmeGwVChigm"
          crossorigin="anonymous">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="~/js/event.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <style>
        .d-none{
            display:none;
        }

        .text-font-size span {
            font-size:16px;
        }

        .tracking-wider1{
            color:white;
        }

        .returnList{
            cursor:pointer;
        }

        .d-none{
            display:none;
        }
        
        .paragraph-justify{
            text-align: justify;
            text-justify: inter-word;
        }

        #scrollTopBtn {
            transform: translateY(20px);
        }

            #scrollTopBtn.show {
                opacity: 1 !important;
                visibility: visible !important;
                transform: translateY(0);
            }
    </style>
</head>
<body class="bg-slate-100 min-h-screen flex flex-col items-center font-sans">
    <header id="headerBoxId" class="w-full fixed top-0 z-50 px-4 py-3 bg-blue-600 hideBox">
        <div class="max-w-full mx-auto bg-gradient-to-r from-blue-600 to-blue-500
                rounded-full px-6 py-3 flex items-center justify-between shadow-lg">

            <!-- LEFT: LOGO -->
            <div class="flex items-center gap-3">
                <a href="@(ViewData["Exam"] == "Hidden" ? "#" : "/")">
                    <img src="~/img/logo2.png" class="h-10 w-auto" alt="logo" />
                </a>
            </div>

            <!-- CENTER: MENU (DESKTOP) -->
            <nav class="hidden md:flex items-center gap-10 text-white font-medium">

                <a href="#home"
                   data-target="home"
                   class="menu-item relative group transition
                        @(ViewContext.RouteData.Values["action"]?.ToString() == "Index"
                           ? "text-white"
                           : "opacity-80 hover:opacity-100")">

                    Trang chủ

                    <span class="underline absolute left-0 -bottom-1 h-[2px] bg-white w-full transition-all duration-300">
                    </span>
                </a>

                <a href="#theLeId" data-target="theLeId"
                   class="menu-item relative group opacity-80 transition">
                    Thể lệ
                    <span class="underline absolute left-0 -bottom-1 h-[2px] bg-white w-0 transition-all duration-300"></span>
                </a>

                <a href="#rankingListId" data-target="rankingListId"
                   class="menu-item relative group opacity-80 transition">
                    Bảng xếp hạng
                    <span class="underline absolute left-0 -bottom-1 h-[2px] bg-white w-0 transition-all duration-300"></span>
                </a>


            </nav>

            <!-- RIGHT -->
            <div class="flex items-center gap-4">

                <!-- MOBILE BUTTON -->
                <button id="menuBtn" class="md:hidden @(ViewData["Exam"] == "Hidden" || ViewData["ExamStart"] == "Hidden" ? "hidden" : "") text-white text-2xl">
                    ☰
                </button>

                <div class="flex flex-col items-end">
                    <span class="text-xs opacity-75 tracking-wider1 d-none">Thời gian còn lại</span>
                    <span id="tracking-wider" class="text-xl font-bold tracking-wider tracking-wider1 d-none">00:00</span>
                </div>

                @if (!User.Identity.IsAuthenticated)
                {
                    <a href="tai-khoan/dang-nhap"
                       class="text-white font-medium hover:underline">
                        Đăng nhập
                    </a>
                }
                else
                {
                    <!-- USER DROPDOWN -->
                    <div class="relative" id="userMenu">
                        <button class="flex items-center gap-2 text-white @(ViewData["Exam"] == "Hidden" ? "" : "toggleUserMenu") ">
                            <img src="@User.FindFirst("Avatar")?.Value"
                                 class="w-8 h-8 rounded-full border border-white" />

                            <span class="hidden sm:block font-medium">
                                @User.FindFirst("FullName")?.Value
                            </span>
                        </button>

                        <!-- DROPDOWN -->
                        <div id="userDropdown"
                             class="hidden absolute right-0 mt-3 w-52 bg-white text-gray-700
                                    rounded-xl shadow-lg overflow-hidden">

                            <div class="px-4 py-3 border-b">
                                <p class="font-medium">@User.FindFirst("FullName")?.Value</p>
                                @* <p class="text-xs text-gray-500">@User.FindFirst("Email")?.Value</p> *@
                            </div>

                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/quan-ly" class="block px-4 py-2 hover:bg-gray-100">
                                    Trang quản lý
                                </a>
                            }

                            <a href="/thong-tin-ca-nhan" class="block px-4 py-2 hover:bg-gray-100">
                                Thông tin cá nhân
                            </a>

                            <a href="/doi-mat-khau" class="block px-4 py-2 hover:bg-gray-100">
                                Đổi mật khẩu
                            </a>

                            <a href="/bai-thi" class="block px-4 py-2 hover:bg-gray-100">
                                Làm bài thi
                            </a>

                            <button onclick="logout()"
                                    class="w-full text-left px-4 py-2 text-red-500 hover:bg-gray-100">
                                Đăng xuất
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- MOBILE MENU -->
        <div id="mobileMenu"
             class="hidden @(ViewData["Exam"] == "Hidden" ? "d-none" : "") md:hidden mt-3 mx-auto max-w-7xl bg-blue-600 text-white rounded-2xl shadow-lg p-4">

            <a href="#home" data-target="home" class="block py-2 border-b border-white/20">Trang chủ</a>
            <a href="#theLeId" data-target="theLeId" class="block py-2 border-b border-white/20">Thể lệ</a>
            <a href="#rankingListId" data-target="rankingListId" class="block py-2">Bảng xếp hạng</a>
        </div>
    </header>    
    @RenderBody()
    <button id="scrollTopBtn"
            class="fixed bottom-20 right-6 bg-blue-600 text-white p-3 rounded-full shadow-lg
           hover:bg-blue-700 transition-all duration-300 opacity-0 invisible">
        <svg xmlns="http://www.w3.org/2000/svg"
             fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"
             class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
        </svg>
    </button>
    <!-- Footer -->
    <section id="footageBoxId" class="w-full bg-blue-600 text-white hideBox">

        <div class="max-w-7xl mx-auto px-4 py-6">

            <div class="grid md:grid-cols-2 gap-10">

                <!-- LEFT: BAN TỔ CHỨC -->
                <div class="text-center md:text-left">
                    <h3 class="text-xl font-bold mb-4 uppercase">
                        Ban tổ chức
                    </h3>

                    <p class="font-semibold mb-2">
                        ĐOÀN THANH NIÊN – HỘI LHTN – HỘI LHPN<br>
                        PHƯỜNG HỒNG AN
                    </p>

                    <p class="text-sm mb-2">
                        Địa chỉ: TDP Nam Hòa, phường Hồng An, TP. Hải Phòng
                    </p>

                    <p class="text-sm">
                        Fanpage: Tuổi trẻ phường Hồng An
                    </p>
                </div>

                <div class="flex justify-center md:justify-end">


                    <!-- QR CODE -->
                    <div class="bg-white p-2 rounded-lg shadow-md">
                        <img src="/img/qr.jpg" alt="QR Code" class="w-60 h-60 object-contain" />
                    </div>

                </div>

            </div>

        </div>

        <!-- FOOTER -->
        <footer class="w-full bg-gradient-to-r from-blue-700 to-blue-600 py-4 text-center">
            <p class="text-sm text-white">
                Copyright © HKmychioca 2026. Designed and developed by HKmychioca
            </p>
        </footer>

    </section>
    <script>
        document.querySelector(".toggleUserMenu")?.addEventListener("click", function () {
            toggleUserMenu();
        });


        const notyf = new Notyf({
            duration: 5000,
            position: { x: 'right', y: 'top' },
            dismissible: true
        });
        function logout() {
            submitAjax({
                url: "/tai-khoan/dang-xuat",
                method: "POST",
                data: {},
                headers:{
                    "RequestVerificationToken": '@GetAntiXsrfRequestToken()'
                },
                success: function(res){
                    if(res.isSuccess){
                        notyf.success(res.message || "Đăng xuất thành công!");
                        if(res.isSuccess){
                            window.location.href = '/';
                        }
                    } else {
                        notyf.error(res.message || "Đăng xuất thất bại!");
                    }
                },
                error: function(xhr){
                    notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
                }
            })
        }

        const btn = document.getElementById("scrollTopBtn");

        window.addEventListener("scroll", () => {
            if (window.scrollY > 300) {
                btn.classList.add("show");
            } else {
                btn.classList.remove("show");
            }
        });

        btn.addEventListener("click", () => {
            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });
        });

        $('.returnList').on('click', function(){
            window.location.href = '/';
        });

        // mobile menu
        document.getElementById("menuBtn")?.addEventListener("click", function () {
            const menu = document.getElementById("mobileMenu");
            menu.classList.toggle("hidden");
        });

        // user dropdown
        function toggleUserMenu() {
            document.getElementById("userDropdown").classList.toggle("hidden");
        }

        // click outside close
        document.addEventListener("click", function (e) {
            const menu = document.getElementById("userMenu");
            if (menu && !menu.contains(e.target)) {
                document.getElementById("userDropdown")?.classList.add("hidden");
            }
        });

        const sections = document.querySelectorAll("section[id]");
        const menuItems = document.querySelectorAll(".menu-item");

        function setActive(id) {
            menuItems.forEach(item => {
                const underline = item.querySelector(".underline");

                if (item.dataset.target === id) {
                    console.log(id);
                    item.classList.remove("opacity-80");
                    underline.classList.add("w-full");
                } else {
                    item.classList.add("opacity-80");
                    underline.classList.remove("w-full");
                }
            });
        }

        window.addEventListener("scroll", () => {
            let current = "";

            sections.forEach(section => {
                const sectionTop = section.offsetTop - 120; // offset header
                const sectionHeight = section.offsetHeight;

                if (scrollY >= sectionTop && scrollY < sectionTop + sectionHeight) {
                    current = section.getAttribute("id");
                }
            });

            if (current) setActive(current);
        });

    </script>
</body>
</html>
