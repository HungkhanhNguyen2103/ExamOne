@{
    ViewData["Title"] = "Lỗi";
    Layout = null;
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Thông báo lỗi</title>
    <script src="~/js/tailwind.js" asp-append-version="true"></script>
    <style>
        body { background: radial-gradient(1000px 600px at 10% 10%, rgba(99,102,241,0.08), transparent), radial-gradient(800px 500px at 90% 90%, rgba(16,185,129,0.04), transparent); }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center px-6">
    <main class="max-w-3xl w-full bg-white/90 backdrop-blur-md rounded-2xl shadow-xl border p-8 md:p-12">
        <div class="flex items-start gap-6">
            <div class="flex-shrink-0 mt-1">
                <div class="h-20 w-20 rounded-full bg-red-50 flex items-center justify-center border border-red-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>

            <div class="flex-1">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Có lỗi xảy ra</h1>
                <p class="mt-2 text-sm text-gray-600">Xin lỗi — máy chủ gặp vấn đề khi xử lý yêu cầu của bạn.</p>

                <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">

                    <button id="backBtn" class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300">Quay lại trang chủ</button>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.getElementById('backBtn').addEventListener('click', () => {
            window.location.href = '/';
        });
    </script>
</body>
</html>