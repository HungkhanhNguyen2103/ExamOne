@{
    ViewData["Title"] = "Bài thi";
}
<main class="flex flex-col items-center justify-center min-h-screen bg-gray-100 p-4">

    <div class="text-9xl font-bold text-red-500 mb-6 animate-bounce">
        ⚠️
    </div>

    <h1 class="text-4xl font-bold text-gray-800 mb-4 text-center">
        Bạn không có quyền truy cập
    </h1>

    <p class="text-gray-600 mb-6 text-center max-w-md">
        Có vẻ bạn đang cố gắng truy cập vào trang mà bạn không được phép.
        Nếu bạn nghĩ đây là lỗi, hãy liên hệ với quản trị viên.
    </p>

    <a href="/" class="bg-blue-500 hover:bg-blue-400 text-white px-6 py-3 rounded-lg shadow-md transition">
        Quay về trang chính
    </a>
</main>
<script>
    $(document).ready(function() {
        window.sessionStorage.clear();
    })
    
</script>