@{
    Layout = "~/Views/Account/_AccountLayout.cshtml";
    ViewData["Title"] = "Đăng nhập";
}
@model AccountModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestToken()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8 mx-4">
    @* <h2 class="text-3xl font-bold text-center text-blue-700 mb-6">ExamOne</h2> *@
    <h3 class="text-lg font-semibold text-center text-gray-600 mb-6">Đăng nhập tài khoản</h3>


    <form id="loginForm" method="POST" class="space-y-5">
        <div>
            <label for="Username" class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
            <input type="text" asp-for="Username" required placeholder="Nhập số điện thoại"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
        </div>

        <div class="relative">
            <label for="Password" class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
            <input id="PasswordInput" type="password" asp-for="Password" required placeholder="Nhập mật khẩu"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none pr-10" />
            <button type="button" id="togglePassword" class="absolute right-2 top-1/2 transform-translate-y-1/2 text-gray-500">
                <i class="fas fa-eye"></i>
            </button>
        </div>


        <div class="flex items-center justify-between text-sm">
            <label for="RememberMe" class="flex items-center">
                <input asp-for="RememberMe" type="checkbox" class="mr-2 accent-blue-600" />
                Ghi nhớ đăng nhập
            </label>
            <a href="#" style="display:none" class="text-blue-600 hover:underline">Quên mật khẩu?</a>
        </div>

        <button type="submit"
                class="w-full bg-blue-600 text-white py-2 rounded-lg font-semibold hover:bg-blue-700 transition">
            Đăng nhập
        </button>
    </form>

