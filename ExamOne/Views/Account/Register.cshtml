@{
    Layout = "~/Views/Account/_AccountLayout.cshtml";
    ViewData["Title"] = "Đăng kí";
}
@model AccountModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestToken()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl p-8 mt-8 mb-8">
    <h2 class="text-3xl font-bold text-center text-blue-700 mb-6">ExamOne</h2>
    <h3 class="text-lg font-semibold text-center text-gray-600 mb-6">Đăng kí tài khoản</h3>

    <form id="registerForm" method="POST" class="space-y-4">

        <div class="row flex">
            <div class="mr-2 w-1/2">
                <label for="Username" class="block font-semibold mb-1 text-gray-700">Tài khoản <span class="text-red-500">*</span></label>
                <input type="text" asp-for="Username" required placeholder="Nhập tài khoản"
                       class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
            </div>

            <div class="ml-2 w-1/2">
                <label for="FullName" class="block font-semibold mb-1 text-gray-700">Họ và tên <span class="text-red-500">*</span></label>
                <input type="text" asp-for="FullName" required placeholder="Nhập họ và tên"
                       class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
            </div>
        </div>
        <div class="row flex">
            <div class="mr-2 w-1/2">
                <label for="Email" class="block font-semibold mb-1 text-gray-700">Email <span class="text-red-500">*</span></label>
                <input type="email" required placeholder="Nhập email" asp-for="Email"
                       class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
            </div>

            <div class="ml-2 w-1/2">
                <label for="CCCD" class="block font-semibold mb-1 text-gray-700">CCCD/CC <span class="text-red-500">*</span></label>
                <input type="text" required asp-for="CCCD" placeholder="Nhập số CCCD/CC"
                       class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
            </div>
        </div>

        <div class="flex">
@*             <div class="mr-2 w-1/2" style="display:none">
                <label for="ProvinceCode" class="block font-semibold mb-1 text-gray-700">Tỉnh/Thành phố <span class="text-red-500">*</span></label>
                <select asp-for="ProvinceCode" required
                        class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none">
                    <option value="">Chọn tỉnh/thành phố</option>
                </select>
            </div>

            <div class="mr-2 w-1/2">
                <label for="WardCode" class="block font-semibold mb-1 text-gray-700">Phường/Xã <span class="text-red-500">*</span></label>
                <select asp-for="WardCode" required
                        class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none">
                    <option value="">Chọn phường/xã</option>
                </select>
            </div> *@
            <div class="w-full">
                <label for="BranchCode" class="block font-semibold mb-1 text-gray-700">Chi đoàn <span class="text-red-500">*</span></label>
                <select asp-for="BranchCode" required
                        class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none">
                    <option value="">Chọn chi đoàn</option>
                    @foreach (BranchModel item in ViewBag.Branches)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="flex">
            <div class="relative mr-2 w-1/2">
                <label for="Password" class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu <span class="text-red-500">*</span></label>
                <input id="Password" type="password" asp-for="Password" required placeholder="Nhập mật khẩu"
                       class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none pr-10" />
                <button type="button" id="togglePassword" class="absolute right-2 top-8 transform-translate-y-1/2 text-gray-500">
                    <i class="fas fa-eye"></i>
                </button>
                <p id="passwordHelp" class="text-sm text-red-500 mt-1 hidden">
                    Mật khẩu phải có ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt.
                </p>
            </div>

            <div class="relative ml-2 w-1/2">
                <label for="PasswordConfirm" class="block text-sm font-medium text-gray-700 mb-1">Nhập lại mật khẩu <span class="text-red-500">*</span></label>
                <input type="password" asp-for="PasswordConfirm" required placeholder="Nhập lại mật khẩu"
                       class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none pr-10" />
                <button type="button" id="togglePasswordConfirm" class="absolute right-2 top-8 transform-translate-y-1/2 text-gray-500">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
        </div>

        <div x-data="{ open: false }" class="flex items-start">
            <input type="checkbox" asp-for="AcceptTerms" required class="mt-1 mr-2">
            <span class="text-sm text-gray-600">
                Tôi đồng ý cho phép hệ thống liên hệ qua email để xác nhận và hỗ trợ tài khoản.
                <span @@click ="open = true" class="text-blue-600 hover:underline cursor-pointer">Xem chi tiết điều khoản</span>.
            </span>

            <div x-show="open"
                 x-cloak
                 @@keydown.escape.window ="open = false">

                <div x-show="open"
                     x-transition.opacity
                     class="fixed inset-0 bg-black/50 z-40"
                     @@click ="open = false"></div>

 
                <div x-show="open"
                     x-transition
                     class="fixed inset-0 z-50 flex items-center justify-center">
                    <div class="bg-white w-11/12 max-w-lg rounded-2xl shadow-lg p-6 relative">
   
                        <button type="button" @@click ="open = false"
                                class="absolute top-3 right-3 text-gray-400 hover:text-gray-600">
                            ✕
                        </button>

                        <h2 class="text-xl font-semibold mb-4 text-gray-800">Điều khoản sử dụng</h2>

                        <div class="max-h-60 overflow-y-auto text-gray-700 space-y-2 pr-2">
                            <p>Chào mừng bạn đến với ứng dụng của chúng tôi. Trước khi sử dụng, vui lòng đọc kỹ các điều khoản sau:</p>
                            <p>1. Người dùng cam kết cung cấp thông tin chính xác khi đăng ký.</p>
                            <p>2. Mọi hành vi gian lận, xâm nhập hoặc phá hoại hệ thống sẽ bị xử lý theo quy định pháp luật.</p>
                            <p>3. Chúng tôi có quyền thay đổi điều khoản mà không cần thông báo trước.</p>
                            <p>4. Khi sử dụng dịch vụ, bạn mặc định đồng ý với các điều khoản này.</p>
                            <p>5. Hãy thường xuyên cập nhật phiên bản mới để đảm bảo an toàn và trải nghiệm tốt nhất.</p>
                            <p>6. Mọi thắc mắc vui lòng liên hệ quản trị viên.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit"
                class="w-full bg-blue-600 text-white font-semibold py-2.5 rounded-lg hover:bg-blue-700 transition duration-200">
            Đăng ký
        </button>

        <p class="text-sm text-center text-gray-600 mt-6">
            Đã có tài khoản?
            <a href="/tai-khoan/dang-nhap" class="text-blue-600 hover:underline font-medium">Đăng nhập</a>
        </p>
        <p class="text-sm text-center mt-4">
            <a href="/" class="text-blue-600 text-center mt-4 hover:underline font-medium">Về trang chủ</a>
        </p>
    </form>

</div>
<script>
    const notyf = new Notyf({
        duration: 5000,
        position: { x: 'right', y: 'top' },
        dismissible: true
    });

    // const provinceSelect = document.getElementById("ProvinceCode");
    // const wardSelect = document.getElementById("WardCode");

    // async function loadProvinces() {
    //   const res = await fetch("https://provinces.open-api.vn/api/v2/p/");
    //   const provinces = await res.json();
    //   provinces.forEach(p => {
    //     const opt = document.createElement("option");
    //     opt.value = p.code;
    //     opt.textContent = p.name;
    //     provinceSelect.appendChild(opt);
    //     provinceSelect.value = 31;
    //   });
    // }

    // provinceSelect.addEventListener("change", async () => {
    //   wardSelect.innerHTML = "<option value=''>Chọn phường/xã</option>";
    //   if (!provinceSelect.value) return;

    //   const res = await fetch(`https://provinces.open-api.vn/api/v2/p/${provinceSelect.value}?depth=2`);
    //   const data = await res.json();

    //   const wards = data.wards;
    //   wards.forEach(w => {
    //     const opt = document.createElement("option");
    //     opt.value = w.code;
    //     opt.textContent = `${w.name}`;
    //     wardSelect.appendChild(opt);
    //   });
    // });

    // loadProvinces();

    const password = document.getElementById("Password");
    const confirmPassword = document.getElementById("PasswordConfirm");
    const passwordHelp = document.getElementById("passwordHelp");
    //const confirmError = document.getElementById("confirmError");

    function validatePassword() {
      const regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
      const valid = regex.test(password.value);
      passwordHelp.classList.toggle("hidden", valid);
      return valid;
    }

    function validateConfirm() {
      const match = password.value === confirmPassword.value;
      //confirmError.classList.toggle("hidden", match);
      return match;
    }

    password.addEventListener("input", validatePassword);
    confirmPassword.addEventListener("input", validateConfirm);


    $("#registerForm").on("submit", function(e){
        e.preventDefault();
        if (!validatePassword() || !validateConfirm()) {
            notyf.error("Vui lòng kiểm tra lại mật khẩu!");
            return;
        } 

        const formData = $(this).serialize();

        submitAjax({
            url: "/tai-khoan/dang-ki",
            method: "POST",
            data: formData,
            headers:{
                "RequestVerificationToken": '@GetAntiXsrfRequestToken()'
            },
            success: function(res){
                console.log(res);
                if(res.isSuccess){
                    notyf.success(res.message || "Đăng kí thành công!");
                    window.location.href = '/';
                } else {
                    notyf.error(res.message || "Đăng kí thất bại!");
                }
            },
            error: function(xhr){
                notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
            }
        });
    });

    const passwordInput = document.getElementById('Password');
    const togglePassword = document.getElementById('togglePassword');
    const icon = togglePassword.querySelector('i');

    togglePassword.addEventListener('click', () => {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);

        icon.classList.toggle('fa-eye');
        icon.classList.toggle('fa-eye-slash');
    });

    const passwordConfirmInput = document.getElementById('PasswordConfirm');
    const toggleConfirmPassword = document.getElementById('togglePasswordConfirm');
    const iconConfirm = toggleConfirmPassword.querySelector('i');

    toggleConfirmPassword.addEventListener('click', () => {
        const type = passwordConfirmInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordConfirmInput.setAttribute('type', type);

        iconConfirm.classList.toggle('fa-eye');
        iconConfirm.classList.toggle('fa-eye-slash');
    });

</script>
