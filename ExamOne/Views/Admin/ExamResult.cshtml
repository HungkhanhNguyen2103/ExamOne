@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Danh sách bài thi";
    var index = 1;
}
@model List<ExamProgressModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestToken()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<main class="flex flex-col sm:flex-row flex-1 p-6 gap-4">

    <section class="sm:w-1/2 w-full bg-white shadow rounded-lg overflow-hidden">
        <div class="flex items-center justify-between p-4 border-b">
            <div class="flex items-center gap-3">
                <h2 class="text-xl font-semibold">Danh sách bài thi</h2>
            </div>
@*             <div class="flex items-center gap-2">
                <button id="openCreate" onclick="window.location.href='/quan-ly/them-cau-hoi'" class="bg-blue-600 text-white px-3 py-1.5 rounded-lg hover:bg-blue-700">
                    <i class="fas fa-plus mr-1"></i> Thêm
                </button>
            </div> *@
        </div>

        <!-- Table -->
        <table id="questionTable" class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-3 py-2 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">STT</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tên</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Bắt đầu</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trạng thái</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Hành động</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200" id="tableBody">
                @foreach (ExamProgressModel item in Model)
                {
                    <tr class="hover:bg-blue-50 cursor-pointer" onclick="showDetail('@item.Id')">
                        <td class="px-2 py-2 text-center">@(index++)</td>
                        <td class="px-2 py-2">@item.CreatedFullName <br /> <small>@item.BranchNameShort</small></td>
                        <td class="px-2 py-2">@item.StartDate.ToString("HH:mm dd/MM/yyyy")</td>
                        <td class="py-2" style="text-align: center;">
                            @if(item.ExamStatus == ExamStatus.Done)
                            {
                                <span style="font-size:9px" class="px-2 py-1 rounded-full bg-green-200 text-green-800 text-sm">
                                    Hoàn thành 
                                </span>
                            }
                            else if (item.ExamStatus == ExamStatus.InProgress)
                            {
                                <span style="font-size:9px" class="px-2 py-1 rounded-full bg-yellow-200 text-yellow-800 text-sm">
                                    Trong tiến trình
                                </span>
                            }
                            else if (item.ExamStatus == ExamStatus.NotYet)
                            {
                                <span style="font-size:9px" class="px-2 py-1 rounded-full bg-gray-300 text-gray-800 text-sm">
                                    Chưa bắt đầu
                                </span>
                            }
                        </td>
                        <td class="px-2 py-2 text-center">
                            <div class="flex justify-center gap-2">
                                <button type="button" onclick="deleteQuestion('@item.Id')"
                                        class="bg-red-500 hover:bg-red-600 text-white px-2 py-1 rounded-md text-xs">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section id="detailPanel" style="height:1000px;overflow:auto" class="sm:w-1/2 w-full bg-white shadow rounded-lg p-6 hidden sm:block">
        <h3 class="text-xl font-semibold mb-2 flex items-center gap-2">
            <i class="fas fa-info-circle text-blue-600"></i> Chi tiết bài thi
        </h3>
        <div id="questionDetail" class="text-gray-700 space-y-2">
            <p>Chọn một bài thi ở bên trái để xem chi tiết.</p>
        </div>

        <div id="loadingSpinner" class="hidden flex justify-center items-center py-6">
            <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-blue-600"></div>
        </div>
    </section>

</main>

<script>
    $('#examListId').addClass('bg-gray-200');
    // const notyf = new Notyf({
    //     duration: 5000,
    //     position: { x: 'right', y: 'top' },
    //     dismissible: true
    // });

    const detailPanel = document.getElementById("detailPanel");
    const questionDetail = document.getElementById("questionDetail");
    const loadingSpinner = document.getElementById("loadingSpinner");

    $(document).ready(function() {
        $('#questionTable').DataTable({
            pageLength: 10,
            lengthMenu: [10,50,100,200],
            columnDefs: [
                { orderable: false, targets: 4 }
            ],
            language: {
                search: "_INPUT_",
                searchPlaceholder: "Tìm kiếm...",
                paginate: {
                    previous: "<",
                    next: ">"
                }
            },
            dom:
                "<'flex justify-between mb-2'lf>" +
                "t" + // table
                "<'flex justify-between mt-2'ip>"
        });

        $('#questionTable tbody').on('click', 'tr', function() {
            $('#questionTable tbody td').removeClass('bg-blue-100');

            $(this).find('td').addClass('bg-blue-100');
        });
    });


    function deleteQuestion(id) {
        if (confirm("Bạn có muốn xóa ?")) {
            submitAjax({
                url: `/quan-ly/xoa-bai-thi/${id}`,
                method: "POST",
                data: {},
                headers:{
                    "RequestVerificationToken": '@GetAntiXsrfRequestToken()'
                },
                success: function(res){
                   if(res.isSuccess){
                        notyf.success(res.message || "Xóa thành công!");
                        setTimeout(() => {
                           window.location.reload();
                        }, 1000);
                    } else {
                        notyf.error(res.message || "Xóa thất bại!");
                    }
                },
                error: function(xhr){
                    notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
                }
            });

        }
    }

    function showDetail(id) {

        detailPanel.classList.remove("hidden");

        questionDetail.classList.add("hidden");
        loadingSpinner.classList.remove("hidden");
        let html = '';
        submitAjax({
            url: `/quan-ly/bai-thi/${id}`,
            method: "POST",
            data: {},
            headers:{
                "RequestVerificationToken": '@GetAntiXsrfRequestToken()'
            },
            success: function(res){
                if(res.isSuccess){
                    console.log(res.data);
                    html += `
                        <p><strong>Họ tên:</strong> ${res.data.createdFullName}</p>
                        <p><strong>Chi nhánh:</strong> ${res.data.branchName}</p>
                        <p><strong>Thời gian làm bài:</strong> ${res.data.complatedDuration ?? ''}</p>
                        <p><strong>Điểm:</strong> ${res.data.totalCorrectAnswers}</p>
                        <hr class="my-3">
                    `;

                    res.data.questions.forEach((question,index) => {
                        let optionHtml = '';
                        question.items.forEach(item => {
                            optionHtml += `<li id="${item.id}"><strong>${String.fromCharCode(65 + item.sortOrder)}.</strong> ${item.optionText}</li>`;
                        })

                        html += `
                            <p><strong>Câu ${++index}:</strong></p>
                            ${question.article}
                            <p>${question.question}</p>
                            <div>
                                <ul>
                                ${optionHtml}
                                </ul>
                            </div>
                            <p>Đáp án đã chọn:<strong> ${question.userAnsweredOptionCharacter ?? ''}</strong></p>
                            <p>Đáp án đúng:<strong> ${question.answeredOptionCharacter}</strong></p>
                            <p>Điểm:<strong> ${question.point}</strong></p>
                            <p>Giải thích: ${question.explanation}</p>
                            <hr>
                        `;
                    })
                    
                    questionDetail.innerHTML = html;
                } else {
                    notyf.error(res.message || "Lấy thông tin thất bại!");
                }
                loadingSpinner.classList.add("hidden");
                questionDetail.classList.remove("hidden");

                if (window.innerWidth < 640) {
                    detailPanel.scrollIntoView({ behavior: "smooth" });
                }
            },
            error: function(xhr){
                notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
            }
        });

    }

</script>
