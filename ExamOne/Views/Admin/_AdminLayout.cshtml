@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestTokenAdmin()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
    <script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <script src="~/js/event.js" asp-append-version="true"></script>

    <style>
        #questionTable_wrapper {
            margin: 1rem;
        }

        #questionTable2_wrapper {
            margin: 1rem;
        }

        .sidebar {
            width: 220px; 
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 1rem;
            background-color: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            z-index: 40;
            transition: transform 0.3s ease;
        }

            .sidebar.hidden {
                transform: translateX(-100%);
            }

            .sidebar nav {
                flex: 1;
                overflow-y: auto;
                margin-bottom: 1rem;
            }

        .sidebar-footer {
            display: flex;
            justify-content: space-around;
            border-top: 1px solid #e5e7eb;
            padding-top: 0.5rem;
        }

            .sidebar-footer button {
                background: none;
                border: none;
                cursor: pointer;
                color: #4B5563;
                padding: 0.5rem;
                border-radius: 4px;
                font-size: 1.25rem;
            }

                .sidebar-footer button:hover {
                    background-color: #E5E7EB;
                }

        .content-wrapper {
            margin-left: 220px;
            flex: 1;
            padding: 1rem;
        }

        .table-fixed thead th {
            position: sticky;
            top: 0;
            background: white;
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside id="sidebar" class="sidebar">
            <div>
                <div class="mb-6 flex items-center justify-between">
                    <div>
                        <h1 class="text-lg font-bold">ExamOne</h1>
                        <p class="text-sm text-gray-500">Quản lý hệ thống</p>
                    </div>
                    <button id="closeSidebar" class="sm:hidden text-gray-600">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <nav class="space-y-1">
                    <a href="/quan-ly" id="dashboardId" class="flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-200">
                        <i class="fas fa-tachometer-alt w-5"></i>
                        <span>Quản lý</span>
                    </a>
                    <a href="/quan-ly/danh-sach-bai-thi" id="examListId" class="flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-200">
                        <i class="fas fa-list w-5"></i>
                        <span>Bài thi</span>
                    </a>
                    <a href="/quan-ly/ngan-hang-cau-hoi" id="questionBankId" class="flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-200">
                        <i class="fas fa-table w-5"></i>
                        <span>Câu hỏi</span>
                    </a>
                    <a href="/quan-ly/cai-dat" id="settingId" class="flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-200">
                        <i class="fas fa-cog w-5"></i>
                        <span>Cài đặt</span>
                    </a>
                </nav>

                <div class="mt-6 border-t pt-4 text-sm text-gray-600">
                    <div class="flex items-center gap-2">
                        <img src="@User.FindFirst("Avatar")?.Value" class="w-8 h-8 rounded-full border border-blue-300" alt="avatar" />
                        <div>
                            <div class="font-medium">@User.FindFirst("FullName")?.Value</div>
                            <div class="text-xs">@User.FindFirst("Email")?.Value</div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="sidebar-footer">
                <button onclick="window.location.href='/'">
                    <i class="fas fa-home"></i>
                </button>
                <button onclick="logout2()">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </div>
        </aside>

        <div id="overlayNav" class="fixed inset-0 bg-black bg-opacity-40 hidden z-30 sm:hidden"></div>

        <main class="content-wrapper">
            @RenderBody()
        </main>
    </div>

    <script>
        $(document).ready(function() {
            const sidebar = $("#sidebar");
            const overlay = $("#overlayNav");

            $("#toggleSidebar").click(function() {
                sidebar.toggleClass("hidden");
                overlay.toggleClass("hidden");
            });

            $("#closeSidebar, #overlayNav").click(function() {
                sidebar.addClass("hidden");
                overlay.addClass("hidden");
            });
        });

        const notyf = new Notyf({
            duration: 5000,
            position: { x: 'right', y: 'top' },
            dismissible: true
        });

        function logout2() {
            submitAjax({
                url: "/tai-khoan/dang-xuat",
                method: "POST",
                data: {},
                headers:{
                    "RequestVerificationToken": '@GetAntiXsrfRequestTokenAdmin()'
                },
                success: function(res){
                    if(res.isSuccess){
                        notyf.success(res.message || "Đăng xuất thành công!");
                        if(res.isSuccess){
                            window.location.href = '/';
                        }
                    } else {
                        notyf.error(res.message || "Đăng xuất thất bại!");
                    }
                },
                error: function(xhr){
                    notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
                }
            })
        }
    </script>
</body>
</html>
