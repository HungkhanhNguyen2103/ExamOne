@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Cài đặt";
}
@model ExamModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestToken()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<main class="flex flex-col sm:flex-row flex-1 p-6 gap-4">

    <section class="sm:w-full w-full bg-white shadow rounded-lg overflow-hidden p-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold">Chi tiết câu hỏi</h2>
        </div>

        <form id="examForm" class="space-y-4">

            <div>
                <label for="Instructions" class="block text-sm font-medium text-gray-700 mb-1">Chỉ dẫn</label>
                <div id="instructionEditor" class="h-40 bg-white border border-gray-300 rounded-lg"></div>
            </div>

            <div>
                <label for="DurationMinutes" class="block text-sm font-medium text-gray-700 mb-1">Thời lượng làm bài (phút)</label>
                <input type="number" asp-for="DurationMinutes" min="0"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
            </div>

            <div>
                <label for="TotalQuestions" class="block text-sm font-medium text-gray-700 mb-1">Số lượng câu hỏi</label>
                <input type="number" asp-for="TotalQuestions" min="0"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
            </div>

            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                Cập nhật
            </button>
        </form>
    </section>

</main>
<script>
    $('#settingId').addClass('bg-gray-200');
    const notyf = new Notyf({
        duration: 5000,
        position: { x: 'right', y: 'top' },
        dismissible: true
    });

    function logout2() {
        submitAjax({
            url: "/tai-khoan/dang-xuat",
            method: "POST",
            data: {},
            headers:{
                "RequestVerificationToken": '@GetAntiXsrfRequestToken()'
            },
            success: function(res){
                if(res.isSuccess){
                    notyf.success(res.message || "Đăng xuất thành công!");
                    if(res.isSuccess){
                        window.location.href = '/';
                    }
                } else {
                    notyf.error(res.message || "Đăng xuất thất bại!");
                }
            },
            error: function(xhr){
                notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
            }
        })
    }


    $(function () {
        const quillInstructions = new Quill('#instructionEditor', { theme: 'snow', placeholder:'Nhập nội dung....' });
        const instructionsContent = @Html.Raw(Json.Serialize(Model?.Instructions ?? ""));
        if (instructionsContent.trim() !== "") {
            quillInstructions.root.innerHTML = instructionsContent;
        }

        $('#examForm').submit(function (e) {
            e.preventDefault();


            const data = {
                DurationMinutes: $('#DurationMinutes').val(),
                TotalQuestions: $('#TotalQuestions').val(),
                Instructions: quillInstructions.root.innerHTML,
            };

            submitAjax({
                url: "/quan-ly/cai-dat",
                method: "POST",
                data: data,
                headers:{
                    "RequestVerificationToken": '@GetAntiXsrfRequestToken()'
                },
                success: function(res){
                    if(res.isSuccess){
                        notyf.success(res.message || "Cập nhật thành công!");
                        setTimeout(() => {
                           window.location.href = `/quan-ly/cai-dat`;
                        }, 1000);
                    } else {
                        notyf.error(res.message || "Cập nhật thất bại!");
                    }
                },
                error: function(xhr){
                    notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
                }
            });
        });
    });

</script>