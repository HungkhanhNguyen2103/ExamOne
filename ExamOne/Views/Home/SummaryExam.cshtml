@{
    ViewData["Title"] = "Tiến độ làm bài";
    ViewData["Exam"] = "Hidden";
}
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
    public string GetAntiXsrfRequestTokenChild()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<!-- Main Summary Section -->
<main style="height: 64vh;" class="max-w-6xl w-full mt-8 bg-white rounded-2xl shadow-lg p-8 mt-8">
    <div class="z-[-1] fixed inset-0 bg-cover bg-center bg-[url('https://images.unsplash.com/photo-1523580494863-6f3031224c94')]
            bg-black/40 bg-blend-darken">
    </div>

    <h2 class="text-xl justify-center flex items-center font-bold text-center text-gray-800 mb-6">
        Tóm tắt tiến độ
        <!-- SVG Table Icon -->
        <button onclick="showQuestion()" class="p-0 ml-1 flex items-center" title="Bảng câu hỏi">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"
                 class="w-5 h-5 text-[#1E56FF]">
                <path d="M3 3h18v2H3V3zm0 4h18v2H3V7zm0 4h18v2H3v-2zm0 4h18v2H3v-2zm0 4h18v2H3v-2z" />
            </svg>
        </button>
        @* <i onclick="showQuestion()" style="cursor:pointer" class="fas fa-table"></i> *@
    </h2>

    <!-- Stats -->
    <div class="flex justify-center gap-6 flex-wrap mb-6">
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-blue-600 rounded"></div>
            <span class="text-sm text-gray-700">Đã trả lời: <strong id="answerCountId">0</strong></span>
        </div>
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-gray-400 rounded"></div>
            <span class="text-sm text-gray-700">Chưa trả lời: <strong id="noAnswerCountId">0</strong></span>
        </div>
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-gray-200 border border-gray-400 rounded"></div>
            <span class="text-sm text-gray-700">Chưa đọc: <strong id="noReadCountId">0</strong></span>
        </div>
    </div>

    <!-- Question Grid -->
    <div class="text-center text-gray-700 mb-4 font-medium">Danh sách câu hỏi</div>
    <div class="grid grid-cols-7 sm:grid-cols-9 md:grid-cols-10 gap-3 justify-items-center" id="listQuestionProgress">
        <!-- Example question buttons -->
    </div>

</main>
<!-- Footer Buttons -->
<div class="flex justify-between w-full max-w-6xl mt-6 mb-10 px-4">
    <button id="backQuestion" type="button" onclick="backQuestion()" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-400 text-white px-6 py-2 rounded-lg shadow-md transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Câu trước
    </button>

    <button id="nextQuestion" type="button" onclick="nextQuestion()" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-400 text-white px-6 py-2 rounded-lg shadow-md transition">
        <span id="nextQuestionText">Câu tiếp theo</span>
        <svg id="nextQuestionIcon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
    </button>
</div>
<script>
    let examSessionId = sessionStorage.getItem('examSessionId');
    let questionCount = sessionStorage.getItem('questionCount');
    $(document).ready(() => {
        $('.tracking-wider1').removeClass('d-none');
        calculationTime();
        getSummary();
    });

    function calculationTime(){
        var startTime = sessionStorage.getItem('startTime');
        var duration = sessionStorage.getItem('duration');
        let remainingTime = getRemainingTime(startTime, duration);
        $('#tracking-wider').html(remainingTime);
        sessionStorage.setItem('remainingTime', remainingTime);

        setInterval(() => {
            let remainingTime = getRemainingTime(startTime,duration);
            $('#tracking-wider').html(remainingTime);
            sessionStorage.setItem('remainingTime',remainingTime);
        },1000);
    }

    function getRemainingTime(startTime, durationMinutes) {
        const start = new Date(startTime);
        const end = new Date(start.getTime() + durationMinutes * 60 * 1000);
        const now = new Date();

        let diff = end - now;

        if (diff <= 0){
            submitExam();
            return `<span>00:00</span>`;
        }

        const minutes = Math.floor(diff / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);

        const mm = String(minutes).padStart(2, '0');
        const ss = String(seconds).padStart(2, '0');
        //if(minutes <= 1) return `<span style="color:#FFA500">${mm}:${ss}</span>`;
        return `${mm}:${ss}`;
    }

    function choiceQuestion(index){
        sessionStorage.setItem('questionIndex',index);
        window.location.href = `/bai-thi/khoi-dong?sId=${examSessionId}`;
    }


    function showQuestion(){
        window.location.href = `/bai-thi/khoi-dong?sId=${examSessionId}`;
    }

    function getSummary(){
        let questionIndex = sessionStorage.getItem('questionIndex');
        $('#backQuestion').prop('disabled', true);
        $('#backQuestion').removeClass('bg-blue-600').addClass('bg-blue-400');
        $('#nextQuestionText').text('Câu tiếp theo');
        $('#nextQuestionIcon').show();
        $('')
        if(questionIndex > 1 && questionIndex <= questionCount){
            $('#backQuestion').prop('disabled', false);
            $('#backQuestion').removeClass('bg-blue-400').addClass('bg-blue-600');
            if(questionIndex == questionCount){
                $('#nextQuestionText').text('Hoàn tất');
                $('#nextQuestionIcon').hide();
            }
        }

        let listQuestionProgress = sessionStorage.getItem('listQuestionProgress');
        let answerCount = 0;
        let noAnswerCount = 0;
        let noReadCount = 0; 
        $('#listQuestionProgress').html('');
        $('#answerCountId').html('0');
        $('#noAnswerCountId').html('0');
        $('#noReadCountId').html('0');
        if(listQuestionProgress){
            let html = '';
            listQuestionProgress = JSON.parse(listQuestionProgress);
            listQuestionProgress.forEach(item => {
                let className = item.answerId ? 'bg-blue-600 text-white' : item.isRead ? 'bg-gray-400 text-white' : 'bg-gray-300 text-gray-700';
                if(item.answerId) answerCount++;
                else if(item.isRead) noAnswerCount++;
                else if(!item.isRead) noReadCount++;
                html += `<button onclick="choiceQuestion(${item.index})" class="w-10 h-10 flex items-center justify-center rounded-lg ${className} font-semibold hover:scale-105 transition">${item.index}</button>`;
            });
            $('#answerCountId').html(answerCount);
            $('#noAnswerCountId').html(noAnswerCount);
            $('#noReadCountId').html(noReadCount);
            $('#listQuestionProgress').html(html);
        }
    }

    function backQuestion(){
        var questionIndex = sessionStorage.getItem('questionIndex');
        choiceQuestion(Number(questionIndex) - 1);
        sessionStorage.setItem('questionIndex',Number(questionIndex) - 1);
    }

    function submitExam(){
        let listQuestionProgressBase = sessionStorage.getItem('listQuestionProgress');
        let data = {
            Id: examSessionId,
            ExamAnswer: listQuestionProgressBase
        }
        submitAjax({
            url: "/bai-thi/hoan-tat",
            method: "POST",
            data: data,
            headers:{
                "RequestVerificationToken": '@GetAntiXsrfRequestTokenChild()'
            },
            success: function(res){
                if(res.isSuccess){
                    window.location.href = `/bai-thi/ket-qua?sId=${examSessionId}`;
                } else {
                    notyf.error(res.message || "Thất bại!");
                }
            },
            error: function(xhr){
                notyf.error("Có lỗi xảy ra khi gửi dữ liệu!");
            }
        })
    }


    function nextQuestion(){
        var questionIndex = sessionStorage.getItem('questionIndex');
        if(questionIndex < questionCount){
            choiceQuestion(Number(questionIndex) + 1);
        }
        else{
            if(confirm("Bạn có muốn nộp bài ?")){
                submitExam();
            }
        }
    }

</script>